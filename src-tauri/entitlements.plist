<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- ── Networking ─────────────────────────────────────────────────────── -->

  <!-- Accept incoming TCP connections (WebSocket server on the dynamic port) -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Make outgoing connections (BLE stack callbacks, future update checks) -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- ── Bluetooth ───────────────────────────────────────────────────────── -->

  <!-- Core Bluetooth — required for BLE communication with the Muse headset -->
  <key>com.apple.security.device.bluetooth</key>
  <true/>

  <!-- ── Calendar ───────────────────────────────────────────────────────── -->

  <!-- Read calendar events via EventKit (requires NSCalendarsUsageDescription in Info.plist) -->
  <key>com.apple.security.personal-information.calendars</key>
  <true/>

  <!-- ── Location ──────────────────────────────────────────────────────── -->

  <!-- CoreLocation — GPS / Wi-Fi location (requires NSLocationWhenInUseUsageDescription in Info.plist) -->
  <key>com.apple.security.personal-information.location</key>
  <true/>

  <!-- ── App Group (shared data with WidgetKit extension) ──────────────── -->

  <key>com.apple.security.application-groups</key>
  <array>
    <string>group.com.neuroskill.skill</string>
  </array>

  <!-- ── Hardened runtime ────────────────────────────────────────────────── -->

  <!-- Allow JIT compilation — required by wgpu/Metal shader compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory — required by some GPU drivers -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

</dict>
</plist>
