# Pre-push gate:
# - default: changed-files scoped checks (fast)
# - full mode: PREPUSH_FULL=1 git push ...

set -euo pipefail

FULL_MODE="${PREPUSH_FULL:-0}"
CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD)"

if [ "$FULL_MODE" = "1" ]; then
  echo "🔎 Pre-push: full mode enabled (PREPUSH_FULL=1)"

  echo "🔎 Pre-push: frontend checks"
  npm run -s check
  npm test

  echo "🔎 Pre-push: Rust clippy"
  cargo clippy --locked --workspace --exclude skill -- -D warnings
  cargo clippy -p skill --locked --features llm-vulkan,screenshots -- -D warnings

  echo "🔎 Pre-push: Rust tests"
  cargo test --locked --workspace --lib

  echo "✅ Pre-push checks passed (full mode)."
  exit 0
fi

# ── Changed-files scoped mode ────────────────────────────────────────────────
# Prefer upstream tracking branch diff; fall back to previous commit.
BASE_REF=""
if git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" >/dev/null 2>&1; then
  BASE_REF="$(git merge-base HEAD "@{upstream}")"
elif git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
  BASE_REF="HEAD~1"
else
  BASE_REF="HEAD"
fi

CHANGED_FILES="$(git diff --name-only "$BASE_REF...HEAD" 2>/dev/null || true)"

if [ -z "$CHANGED_FILES" ]; then
  echo "✅ Pre-push checks passed (no changed files detected)."
  exit 0
fi

echo "🔎 Pre-push: scoped mode on branch '$CURRENT_BRANCH'"

echo "Changed files baseline: $BASE_REF"

# ── Frontend scoped checks ───────────────────────────────────────────────────
FRONTEND_CHANGED="$(echo "$CHANGED_FILES" | grep -E '^(src/|scripts/|package.json|package-lock.json|svelte.config.js|vite.config.js|tsconfig.json|biome.json)' || true)"
if [ -n "$FRONTEND_CHANGED" ]; then
  echo "🔎 Pre-push: frontend checks (changed files)"

  FRONTEND_BIOME_FILES="$(echo "$FRONTEND_CHANGED" | grep -E '\.(ts|js|svelte|json)$' || true)"
  if [ -n "$FRONTEND_BIOME_FILES" ]; then
    # shellcheck disable=SC2086
    npx biome check --no-errors-on-unmatched $FRONTEND_BIOME_FILES
  fi

  VITEST_RELATED_FILES="$(echo "$FRONTEND_CHANGED" | grep -E '^src/.*\.(ts|js|svelte)$' || true)"
  if [ -n "$VITEST_RELATED_FILES" ]; then
    # shellcheck disable=SC2086
    npx vitest related --run $VITEST_RELATED_FILES
  fi
fi

# ── Rust scoped checks ───────────────────────────────────────────────────────
RUST_CHANGED="$(echo "$CHANGED_FILES" | grep -E '\.rs$|^Cargo.toml$|^Cargo.lock$|^src-tauri/Cargo.toml$|^crates/.*/Cargo.toml$' || true)"
if [ -n "$RUST_CHANGED" ]; then
  echo "🔎 Pre-push: Rust checks (changed crates)"
  cargo fmt --check

  declare -a CRATES=()
  NEED_SKILL=0

  while IFS= read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
      crates/*)
        crate_dir="${f#crates/}"
        crate_name="${crate_dir%%/*}"
        if [[ "$crate_name" == skill-* ]]; then
          CRATES+=("-p" "$crate_name")
        fi
        ;;
      src-tauri/*)
        NEED_SKILL=1
        ;;
      Cargo.toml|Cargo.lock)
        NEED_SKILL=1
        ;;
    esac
  done <<< "$CHANGED_FILES"

  # Deduplicate crate flags (bash 3 compatible)
  if [ "${#CRATES[@]}" -gt 0 ]; then
    uniq_pairs="$(printf '%s\n' "${CRATES[@]}" | awk 'NR%2{p=$0;next}{print p" "$0}' | sort -u)"
    CRATES=()
    while IFS= read -r pair; do
      [ -z "$pair" ] && continue
      CRATES+=("${pair%% *}" "${pair#* }")
    done <<EOF
$uniq_pairs
EOF
  fi

  if [ "${#CRATES[@]}" -gt 0 ]; then
    cargo clippy --locked "${CRATES[@]}" -- -D warnings
    cargo test --locked "${CRATES[@]}" --lib
  else
    cargo clippy --locked --workspace --exclude skill -- -D warnings
    cargo test --locked --workspace --exclude skill --lib
  fi

  if [ "$NEED_SKILL" -eq 1 ]; then
    cargo clippy -p skill --locked -- -D warnings
    cargo test -p skill --locked --lib
  fi
fi

echo "✅ Pre-push checks passed (scoped mode)."
